{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quill",
  "version": "0.1.17",
  "identifier": "com.quill.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Quill \u2014 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438",
        "width": 460,
        "height": 580,
        "resizable": true,
        "center": true,
        "visible": false,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "editor",
        "title": "Quill",
        "url": "editor.html",
        "width": 400,
        "height": 560,
        "minWidth": 340,
        "minHeight": 380,
        "resizable": true,
        "center": true,
        "visible": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2QzI3NzlGNjExRTE0QjEKUldTeEZCNWhuM2ZDdG5DTkdMTGlsVkd2Y21ZeWZiZzNHbko2bnA2Z1RUYkIzSHlEVlRpNlNYRXoK",
      "endpoints": [
        "https://github.com/olegperegudov/quill/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}